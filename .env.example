GEMINI_BASE_URL=https://api.gapgpt.app/v1
GAPGPT_API_KEY=

# --- Graphiti indexing (ingestion.config.graphiti) --------------------------------
GRAPHITI_INDEX_LLM_BASE_URL=https://api.gapgpt.app/v1
GRAPHITI_INDEX_LLM_API_KEY=
GRAPHITI_INDEX_LLM_MODEL=gpt-4o-mini

# Graphiti cross-encoder: set true only on providers that support logprob reranking (``logit_bias`` + ``top_logprobs``).
GRAPHITI_RERANKER_USE_LOGIT_BIAS=

# Reranker (optional; each empty value falls back to GRAPHITI_INDEX_LLM_BASE_URL / GRAPHITI_INDEX_LLM_API_KEY / GRAPHITI_INDEX_LLM_MODEL)
GRAPHITI_INDEX_RERANKER_BASE_URL=
GRAPHITI_INDEX_RERANKER_API_KEY=
GRAPHITI_INDEX_RERANKER_MODEL=

GRAPHITI_INDEX_EMBEDDING_BASE_URL=https://api.gapgpt.app/v1
GRAPHITI_INDEX_EMBEDDING_API_KEY=
GRAPHITI_INDEX_EMBEDDING_MODEL=text-embedding-3-large
GRAPHITI_INDEX_EMBEDDING_DIM=3072

# Optional: overrides built-in English extraction hints for biology/Persian (ingestion.graph.graph). Empty = default.
GRAPHITI_CUSTOM_EXTRACTION_INSTRUCTIONS=

# --- Other ingestion (e.g. ingestion.config.embedding) ----------------------------
EMBEDDING_BASE_URL=https://api.gapgpt.app/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# Neo4j configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# FalkorDB (Graphiti maps group_id to graph name when != driver.database)
FALKOR_HOST=127.0.0.1
FALKOR_PORT=6379
FALKOR_DATABASE=default_db
# Falkor GRAPH.QUERY timeout (ms). Default 300000 if unset; use 0 for server-only default (often too low for ingest).
FALKOR_QUERY_TIMEOUT_MS=
