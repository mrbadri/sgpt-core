# =============================================================================
# Graphiti indexing — LLM (OpenAI-compatible)
# =============================================================================
GRAPHITI_INDEX_LLM_BASE_URL=https://api.gapgpt.app/v1
GRAPHITI_INDEX_LLM_API_KEY=your-gapgpt-or-openai-compatible-api-key
GRAPHITI_INDEX_LLM_MODEL=gpt-5-mini

# GRAPHITI_INDEX_LLM_MODEL=gpt-5-nano
# GRAPHITI_INDEX_LLM_MODEL=gpt-4o-mini
# GRAPHITI_INDEX_LLM_MODEL=gemini-3-flash-preview
# GRAPHITI_INDEX_LLM_BASE_URL=https://your-llm-provider.example/v1
# GRAPHITI_INDEX_LLM_API_KEY=your-api-key

# =============================================================================
# Graphiti reranker — options
# =============================================================================
GRAPHITI_RERANKER_USE_LOGIT_BIAS=false

# =============================================================================
# Graphiti indexing — reranker / cross-encoder (optional — unset keys fall back to GRAPHITI_INDEX_LLM_*)
# =============================================================================
GRAPHITI_INDEX_RERANKER_BASE_URL=https://api.gapgpt.app/v1
GRAPHITI_INDEX_RERANKER_API_KEY=your-gapgpt-or-openai-compatible-api-key
GRAPHITI_INDEX_RERANKER_MODEL=gpt-4o-mini

# =============================================================================
# Graphiti indexing — embeddings
# =============================================================================
GRAPHITI_INDEX_EMBEDDING_BASE_URL=https://api.gapgpt.app/v1
GRAPHITI_INDEX_EMBEDDING_API_KEY=your-gapgpt-or-openai-compatible-api-key
GRAPHITI_INDEX_EMBEDDING_MODEL=text-embedding-3-large
GRAPHITI_INDEX_EMBEDDING_DIM=3072

#   GRAPHITI_CUSTOM_EXTRACTION_INSTRUCTIONS=

# =============================================================================
# Other ingestion pipelines (semantic split, loaders, …) — not used by ingestion.config.graphiti
# =============================================================================
EMBEDDING_BASE_URL=https://api.gapgpt.app/v1
EMBEDDING_API_KEY=your-gapgpt-or-openai-compatible-api-key
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# =============================================================================
# Agent chat model
# =============================================================================
# AGENT_CHAT_MODEL=gpt-5.1
# AGENT_CHAT_MODEL=gapgpt-qwen-3.6
# AGENT_CHAT_API_KEY=your-api-key
# AGENT_CHAT_BASE_URL=https://api.gapgpt.app/v1
AGENT_CHAT_MODEL=gemini-3-flash-preview
AGENT_CHAT_API_KEY=your-agent-chat-api-key
AGENT_CHAT_BASE_URL=https://api.gapgpt.app/v1
AGENT_CHAT_TEMPERATURE=0.1
AGENT_CHAT_MAX_TOKENS=8192

# =============================================================================
# Graphiti search preset
# =============================================================================
GRAPHITI_SEARCH_PRESET=rrf
GRAPHITI_SEARCH_LIMIT=20
GRAPHITI_SEARCH_REUSE_CLIENT=true

# =============================================================================
# Ingestion / tracing
# =============================================================================
INGEST_TRACE_TIMING=1
INGEST_GRAPHITI_TRACE=1
INGEST_GRAPHITI_TRACE_VERBOSE=1

# =============================================================================
# Optional: LangChain / LangSmith
# =============================================================================
LANGSMITH_API_KEY=your-langsmith-api-key
LANGCHAIN_TRACING_V2=true

# =============================================================================
# Bale bot
# =============================================================================
# BALE_BOT_TOKEN=your-main-bot-token
# BALE_BOT_TOKEN=your-uat-bot-token
BALE_BOT_TOKEN=your-bale-bot-token
BALE_API_URL=https://tapi.bale.ai/bot{0}/{1}
BALE_BOT_PHONE=
# BALE_PAYMENT_PROVIDER_TOKEN=your-test-wallet-token
# BALE_PAYMENT_PROVIDER_TOKEN=your-main-wallet-token
BALE_PAYMENT_PROVIDER_TOKEN=your-bale-payment-provider-token
# BALE_REQUIRED_CHANNELS=["channel-id-1","channel-id-2"]
# BALE_REQUIRED_CHANNELS=["@your_channel"]

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_USER=bale_bot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bale_bot
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB (host db). Postgres only applies
# POSTGRES_* on first start; if you change the password here, run ALTER USER or recreate the volume.
# If the password contains @ : / # % etc., percent-encode it in DATABASE_URL (see RFC 3986).
DATABASE_URL=postgresql://bale_bot:changeme@db:5432/bale_bot

# =============================================================================
# pgAdmin (prod) — .local allowed via PGADMIN_CONFIG_ALLOW_SPECIAL_EMAIL_DOMAINS in docker-compose.prod.yml
# =============================================================================
# Required for infrastructure/docker-compose.prod.yml (Compose ${...} interpolation).
# Addresses under .local work when compose sets PGADMIN_CONFIG_ALLOW_SPECIAL_EMAIL_DOMAINS
# to a Python literal, e.g. "['local']" (see docker-compose.prod.yml pgadmin service).
PGADMIN_DEFAULT_EMAIL=admin@sgpt.local
PGADMIN_DEFAULT_PASSWORD=changeme

# =============================================================================
# FALKOR / FalkorDB configuration
# =============================================================================
# FalkorDB (prod docker service)
# Passed to Compose as ``redis-server --requirepass``; backend/ingestion read the same env.
# Prefer single-quoting values with ``@``, ``|``, or ``\`` so dotenv parsers do not escape them.
FALKORDB_PASSWORD=changeme
FALKOR_HOST=falkordb
FALKOR_PORT=6379
# FALKOR_DATABASE=your-graph-name
# FALKOR_HOST=your-falkor-host
# FALKOR_PORT=7379
# Falkor Browser / FalkorDriver: with ``redis-server --requirepass``, Redis ACL username is ``default``.
# Leave blank only when Falkor runs with no password. Do not use host name ``falkordb`` as username.
FALKOR_USERNAME=default
# FALKOR_QUERY_TIMEOUT_MS=

# =============================================================================
# App secrets / misc
# =============================================================================
# ADMIN_SECRET_KEY=change-me-admin-secret-key-min-32-chars
# SECRET_KEY=change-me-secret-key-min-32-chars-long

# USER_MEMORIES_DIR=user_memories

# =============================================================================
# Web (Next.js) — docker-compose dev/prod web service
# =============================================================================
# Browser-visible API base (no trailing slash). From the host: dev backend :8000, prod :8800.
# For **production** images, NEXT_PUBLIC_* is baked in at `docker compose build` time; change the
# value here (or in the shell) and rebuild the `web` image for client bundles to pick it up.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Server-side fetch from inside Docker (Next SSR / Route Handlers): use service hostname.
API_URL_INTERNAL=http://backend:8000
